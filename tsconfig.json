{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["ES2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "ES2022"
    },
    "include": ["src/**/*", "test/**/*", "vitest.config.ts"],
    "typeRoots": ["node_modules/@types", "src/types"],
    "exclude": ["node_modules", "dist", "tsdown.config.ts", "test/exports.spec.ts"]
}
