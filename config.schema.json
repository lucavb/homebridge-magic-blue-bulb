{
    "pluginAlias": "MagicBlueBulbPlatform",
    "pluginType": "platform",
    "singular": false,
    "strictValidation": true,
    "headerDisplay": "Configure your MagicBlue LED Bulbs via Bluetooth Low Energy (BLE). Make sure your Homebridge system has Bluetooth capabilities and the bulbs are within range.",
    "footerDisplay": "For help and examples, please see the [plugin documentation](https://github.com/lucavb/homebridge-magic-blue-bulb#readme). Warm white and state sync features are beta — please report results in GitHub issues.",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Platform Name",
                "type": "string",
                "default": "Magic Blue Bulbs",
                "minLength": 1,
                "description": "The name for this platform instance"
            },
            "platform": {
                "type": "string",
                "const": "MagicBlueBulbPlatform"
            },
            "bulbs": {
                "title": "Bulb Configurations",
                "type": "array",
                "minItems": 1,
                "description": "Configure each MagicBlue bulb you want to control",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "title": "Bulb Name",
                            "type": "string",
                            "minLength": 1,
                            "placeholder": "Living Room Light",
                            "description": "The name for this bulb as it will appear in HomeKit"
                        },
                        "mac": {
                            "title": "MAC Address",
                            "type": "string",
                            "pattern": "^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$",
                            "placeholder": "AA:BB:CC:DD:EE:FF",
                            "description": "The Bluetooth MAC address of the bulb (format: AA:BB:CC:DD:EE:FF or AA-BB-CC-DD-EE-FF)"
                        },
                        "handle": {
                            "title": "BLE Write Handle (Optional)",
                            "type": "integer",
                            "minimum": 1,
                            "default": 12,
                            "placeholder": 12,
                            "description": "GATT write handle for commands (default 12 / 0x000c). Some newer bulbs may need a different value — check plugin docs."
                        },
                        "readHandle": {
                            "title": "BLE Read Handle (Optional)",
                            "type": "integer",
                            "minimum": 1,
                            "default": 15,
                            "placeholder": 15,
                            "description": "GATT read handle for status responses (default 15 / 0x000f)"
                        },
                        "version": {
                            "title": "Bulb Version (Optional)",
                            "type": "integer",
                            "enum": [6, 7, 8, 9, 10],
                            "description": "Firmware version shown in the official app. Used to pick the BLE address type if addressType is not set (v7/v8 = random, v6/v9/v10 = public)."
                        },
                        "addressType": {
                            "title": "BLE Address Type (Optional)",
                            "type": "string",
                            "enum": ["public", "random"],
                            "description": "Override BLE address type for connection. Leave unset to derive from version or MAC."
                        },
                        "debug": {
                            "title": "Debug BLE Traffic",
                            "type": "boolean",
                            "default": false,
                            "description": "Log raw BLE writes and reads to the Homebridge log (useful for issue reports)"
                        },
                        "manufacturer": {
                            "title": "Manufacturer (Optional)",
                            "type": "string",
                            "placeholder": "MagicBlue",
                            "description": "Optional: Manufacturer name for HomeKit display"
                        },
                        "model": {
                            "title": "Model (Optional)",
                            "type": "string",
                            "placeholder": "Magic Blue v2",
                            "description": "Optional: Model name for HomeKit display"
                        },
                        "serial": {
                            "title": "Serial Number (Optional)",
                            "type": "string",
                            "placeholder": "MB001234",
                            "description": "Optional: Serial number for HomeKit display"
                        }
                    },
                    "required": ["name", "mac"]
                }
            }
        },
        "required": ["name", "platform", "bulbs"]
    },
    "layout": [
        {
            "type": "fieldset",
            "title": "Platform Settings",
            "expandable": true,
            "expanded": false,
            "items": ["name"]
        },
        {
            "type": "fieldset",
            "title": "Bulb Configuration",
            "expandable": true,
            "expanded": true,
            "items": [
                {
                    "key": "bulbs",
                    "type": "array",
                    "orderable": true,
                    "buttonText": "Add Bulb",
                    "items": [
                        {
                            "type": "fieldset",
                            "title": "{{ bulbs[arrayIndex].name || 'New Bulb' }}",
                            "expandable": true,
                            "expanded": true,
                            "items": [
                                {
                                    "key": "bulbs[].name",
                                    "type": "string"
                                },
                                {
                                    "key": "bulbs[].mac",
                                    "type": "string"
                                },
                                {
                                    "type": "fieldset",
                                    "title": "Optional Settings",
                                    "expandable": true,
                                    "expanded": false,
                                    "items": [
                                        {
                                            "key": "bulbs[].handle",
                                            "type": "number"
                                        },
                                        {
                                            "key": "bulbs[].readHandle",
                                            "type": "number"
                                        },
                                        {
                                            "key": "bulbs[].version",
                                            "type": "number"
                                        },
                                        {
                                            "key": "bulbs[].addressType",
                                            "type": "select"
                                        },
                                        {
                                            "key": "bulbs[].debug",
                                            "type": "checkbox"
                                        },
                                        {
                                            "key": "bulbs[].manufacturer",
                                            "type": "string"
                                        },
                                        {
                                            "key": "bulbs[].model",
                                            "type": "string"
                                        },
                                        {
                                            "key": "bulbs[].serial",
                                            "type": "string"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
